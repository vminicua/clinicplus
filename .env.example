# Copy this file to .env and replace the placeholder values below.

# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Database
# Use your remote database values here. Change DB_ENGINE if your server uses PostgreSQL.
DB_ENGINE=django.db.backends.mysql
DB_NAME=clinicplus_db
DB_USER=clinicplus_user
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5522

# Optional MySQL timeouts
MYSQL_CONNECT_TIMEOUT=5
MYSQL_READ_TIMEOUT=10
MYSQL_WRITE_TIMEOUT=10

# Optional superuser values for non-interactive setup
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
